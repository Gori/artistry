{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["../web/*"],
      "@shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../web/components/**/*.ts",
    "../web/components/**/*.tsx",
    "../web/hooks/**/*.ts",
    "../web/lib/**/*.ts",
    "../web/convex/**/*.ts",
    "electron.vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
