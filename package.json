{
  "name": "artistry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @artistry/web dev",
    "dev:convex": "pnpm --filter @artistry/web exec convex dev",
    "dev:electron": "pnpm --filter @artistry/electron dev",
    "dev:all": "pnpm dev & pnpm dev:convex",
    "build": "pnpm --filter @artistry/web build",
    "build:electron": "pnpm --filter @artistry/electron build",
    "package:electron": "pnpm --filter @artistry/electron package",
    "start": "pnpm --filter @artistry/web start",
    "lint": "pnpm --filter @artistry/web lint",
    "typecheck": "pnpm -r typecheck"
  }
}
